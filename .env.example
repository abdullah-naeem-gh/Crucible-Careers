SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Dashboard > Project Settings > API Keys. Use the new publishable/secret
# keys (sb_publishable_..., sb_secret_...), not the legacy anon/service_role JWTs.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only — never expose to the client. Used for account deletion (auth.admin.deleteUser).
SUPABASE_SECRET_KEY=

# Google Calendar OAuth app (Google Cloud Console) — register
# ${NEXT_PUBLIC_SITE_URL}/api/employer/calendar/google/callback as an authorized
# redirect URI, and enable the Google Calendar API.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft Outlook Calendar OAuth app (Azure Portal > App registrations) —
# register ${NEXT_PUBLIC_SITE_URL}/api/employer/calendar/microsoft/callback as a
# redirect URI, and grant the Calendars.ReadWrite Graph API permission.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Groq API (console.groq.com) — server-only, used to generate AI-suggested
# job description/responsibilities/requirements from a job title.
GROQ_API_KEY=

# Resend transactional email — server-only.
RESEND_API_KEY=
EMAIL_FROM=Crucible Careers <notifications@example.com>
